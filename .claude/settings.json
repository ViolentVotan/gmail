{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(xcodebuild *)",
      "Bash(swift *)",
      "Bash(open *.xcodeproj)",
      "Read(docs/**)",
      "Read(Vik/**)",
      "Read(VikTests/**)"
    ],
    "deny": [
      "Edit(Vik/Configuration/**)"
    ]
  },
  "plansDirectory": "./docs/superpowers/plans",
  "worktree": {
    "sparsePaths": [
      "Vik/",
      "Vik.xcodeproj/",
      "VikTests/",
      "docs/",
      "scripts/",
      ".serena/",
      "CLAUDE.md",
      ".claude/"
    ]
  }
}
